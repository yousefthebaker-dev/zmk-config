// See https://zmk.dev/docs/development/hardware-integration/physical-layouts
// for how to configure this.

#include <physical_layouts.dtsi>

/ {
    default_layout: default_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        kscan = <&kscan>;

        // Edit this to define the positions and sizes of the keys, or remove it
        // if your keyboard will not support ZMK Studio.
        // https://zmk.dev/docs/development/hardware-integration/physical-layouts#optional-keys-property
        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100    0    0       0     0     0>   // 6
            , <&key_physical_attrs 100 100  100    0       0     0     0>   // 7
            , <&key_physical_attrs 100 100  200    0       0     0     0>   // 8
            , <&key_physical_attrs 100 100  300    0       0     0     0>   // 9
            , <&key_physical_attrs 100 100  400    0       0     0     0>   // 0
            , <&key_physical_attrs 100 100    0  100       0     0     0>   // y
            , <&key_physical_attrs 100 100  100  100       0     0     0>   // u
            , <&key_physical_attrs 100 100  200  100       0     0     0>   // i
            , <&key_physical_attrs 100 100  300  100       0     0     0>   // o
            , <&key_physical_attrs 100 100  400  100       0     0     0>   // p
            , <&key_physical_attrs 100 100    0  200       0     0     0>   // h
            , <&key_physical_attrs 100 100  100  200       0     0     0>   // j
            , <&key_physical_attrs 100 100  200  200       0     0     0>   // k
            , <&key_physical_attrs 100 100  300  200       0     0     0>   // l
            , <&key_physical_attrs 100 100  400  200       0     0     0>   // ;
            , <&key_physical_attrs 100 100    0  300       0     0     0>   // n
            , <&key_physical_attrs 100 100  100  300       0     0     0>   // m
            , <&key_physical_attrs 100 100  200  300       0     0     0>   // ,
            , <&key_physical_attrs 100 100  300  300       0     0     0>   // .
            , <&key_physical_attrs 100 100  400  300       0     0     0>   // /
            , <&key_physical_attrs 100 100    0  400       0     0     0>   // Lctrl
            , <&key_physical_attrs 100 100  100  400       0     0     0>   // Spc
            , <&key_physical_attrs 100 100  200  400       0     0     0>   // Bksc
            , <&key_physical_attrs 100 100  300  400       0     0     0>   // Mute
            , <&key_physical_attrs   1   1  500  500       0     0     0>   // No switch
            ;
    };
};

// See https://zmk.dev/docs/development/hardware-integration/physical-layouts
// for how to configure this.

#include <physical_layouts.dtsi>

/ {
    default_layout: default_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        kscan = <&kscan>;

        // Edit this to define the positions and sizes of the keys, or remove it
        // if your keyboard will not support ZMK Studio.
        // https://zmk.dev/docs/development/hardware-integration/physical-layouts#optional-keys-property
        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100    0    0       0     0     0>   // L0 C0
            , <&key_physical_attrs 100 100  100    0       0     0     0>   // L0 C1
            , <&key_physical_attrs 100 100  200    0       0     0     0>   // L0 C2
            , <&key_physical_attrs 100 100  300    0       0     0     0>   // L0 C3
            , <&key_physical_attrs 100 100  400    0       0     0     0>   // L0 C4
            , <&key_physical_attrs 100 100  600    0       0     0     0>   // R0 C0
            , <&key_physical_attrs 100 100  700    0       0     0     0>   // R0 C1
            , <&key_physical_attrs 100 100  800    0       0     0     0>   // R0 C2
            , <&key_physical_attrs 100 100  900    0       0     0     0>   // R0 C3
            , <&key_physical_attrs 100 100 1000    0       0     0     0>   // R0 C4
            , <&key_physical_attrs 100 100    0  100       0     0     0>   // L1 C0
            , <&key_physical_attrs 100 100  100  100       0     0     0>   // L1 C1
            , <&key_physical_attrs 100 100  200  100       0     0     0>   // L1 C2
            , <&key_physical_attrs 100 100  300  100       0     0     0>   // L1 C3
            , <&key_physical_attrs 100 100  400  100       0     0     0>   // L1 C4
            , <&key_physical_attrs 100 100  600  100       0     0     0>   // R1 C0
            , <&key_physical_attrs 100 100  700  100       0     0     0>   // R1 C1
            , <&key_physical_attrs 100 100  800  100       0     0     0>   // R1 C2
            , <&key_physical_attrs 100 100  900  100       0     0     0>   // R1 C3
            , <&key_physical_attrs 100 100 1000  100       0     0     0>   // R1 C4
            , <&key_physical_attrs 100 100    0  200       0     0     0>   // L2 C0
            , <&key_physical_attrs 100 100  100  200       0     0     0>   // L2 C1
            , <&key_physical_attrs 100 100  200  200       0     0     0>   // L2 C2
            , <&key_physical_attrs 100 100  300  200       0     0     0>   // L2 C3
            , <&key_physical_attrs 100 100  400  200       0     0     0>   // L2 C4
            , <&key_physical_attrs 100 100  600  200       0     0     0>   // R2 C0
            , <&key_physical_attrs 100 100  700  200       0     0     0>   // R2 C1
            , <&key_physical_attrs 100 100  800  200       0     0     0>   // R2 C2
            , <&key_physical_attrs 100 100  900  200       0     0     0>   // R2 C3
            , <&key_physical_attrs 100 100 1000  200       0     0     0>   // R2 C4
            , <&key_physical_attrs 100 100    0  300       0     0     0>   // L3 C0
            , <&key_physical_attrs 100 100  100  300       0     0     0>   // L3 C1
            , <&key_physical_attrs 100 100  200  300       0     0     0>   // L3 C2
            , <&key_physical_attrs 100 100  300  300       0     0     0>   // L3 C3
            , <&key_physical_attrs 100 100  400  300       0     0     0>   // L3 C4
            , <&key_physical_attrs 100 100  600  300       0     0     0>   // R3 C0
            , <&key_physical_attrs 100 100  700  300       0     0     0>   // R3 C1
            , <&key_physical_attrs 100 100  800  300       0     0     0>   // R3 C2
            , <&key_physical_attrs 100 100  900  300       0     0     0>   // R3 C3
            , <&key_physical_attrs 100 100 1000  300       0     0     0>   // R3 C4
            , <&key_physical_attrs 100 100    0  400       0     0     0>   // L4 C0
            , <&key_physical_attrs 100 100  100  400       0     0     0>   // L4 C1
            , <&key_physical_attrs 100 100  200  400       0     0     0>   // L4 C2
            , <&key_physical_attrs 100 100  300  400       0     0     0>   // L4 C3
            , <&key_physical_attrs 100 100  400  400       0     0     0>   // L4 C4
            , <&key_physical_attrs 100 100  600  400       0     0     0>   // R4 C0
            , <&key_physical_attrs 100 100  700  400       0     0     0>   // R4 C1
            , <&key_physical_attrs 100 100  800  400       0     0     0>   // R4 C2
            , <&key_physical_attrs 100 100  900  400       0     0     0>   // R4 C3
            , <&key_physical_attrs 100 100 1000  400       0     0     0>   // R4 C4
            ;
    };
};
